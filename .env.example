# XHS Extractor Configuration

# Optional: XHS Cookie for accessing login-required content
# Get from browser DevTools > Application > Cookies > xiaohongshu.com
XHS_COOKIE=

# LLM Provider: "grok", "openai", or "anthropic"
LLM_PROVIDER=grok

# LLM API Key (从 https://console.x.ai 获取 Grok API Key)
LLM_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxx

# LLM Model
# Grok: grok-3, grok-3-mini, grok-2
# OpenAI: gpt-4o
# Anthropic: claude-sonnet-4-6
LLM_MODEL=grok-3

# Optional: Custom API base URL (留空使用默认地址)
LLM_BASE_URL=

# Flask
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false
